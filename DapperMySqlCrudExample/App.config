<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!--
      請依實際環境修改以下連線字串。
      建議在生產環境中透過環境變數或機密管理工具取得 Password，
      避免將密碼硬寫在設定檔中。
    -->
    <add name="DefaultConnection"
         connectionString="Server=localhost;Port=3306;Database=your_db;Uid=your_user;Pwd=your_password;CharSet=utf8mb4;AllowUserVariables=true;SslMode=none;"
         providerName="MySql.Data.MySqlClient" />
  </connectionStrings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6" />
  </startup>
</configuration>

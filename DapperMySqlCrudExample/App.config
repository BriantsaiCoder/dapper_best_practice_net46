<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!--
      DefaultConnection 僅作為本機維護或部署前驗證的後備設定。
      正式環境請優先使用 MYSQL_CONNECTION_STRING 環境變數，
      並透過機密管理工具提供帳密，避免將敏感資訊寫入設定檔。

      MySQL 驅動與連線字串說明：
        • 本專案目前鎖定 MySql.Data 6.10.9，設定與行為應以 6.x 驅動為準。
        • 6.x 與 8.x 在 BeginTransaction / Commit / Rollback 的基本同步 API 一致，
          因此目前程式碼仍以 IDbTransaction + using 管理交易，不需為此重構。
        • 若未來升級至 MySql.Data 8.x，可再評估 async 交易 API 與 TransactionScope，
          但升級前請重新確認 SSL 預設、伺服器版本與連線參數。
    -->
      <!--
        <add name="DefaultConnection"
          connectionString="Server=10.16.92.67;Port=3306;Database=dct;Uid=5910;Pwd=TID_5910!;CharSet=utf8mb4;MinimumPoolSize=5;MaximumPoolSize=100;ConnectionLifeTime=300;DefaultCommandTimeout=30;"
         providerName="MySql.Data.MySqlClient" />
             -->
    <add name="DefaultConnection"
          connectionString="Server=localhost;Port=3306;Database=dct;Uid=root;Pwd=root;CharSet=utf8mb4;MinimumPoolSize=5;MaximumPoolSize=100;ConnectionLifeTime=300;DefaultCommandTimeout=30;"
         providerName="MySql.Data.MySqlClient" />
  </connectionStrings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6.1" />
  </startup>
</configuration>

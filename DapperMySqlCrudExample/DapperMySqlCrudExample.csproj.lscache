/debug+
/debug:portable
/filealign:512
/optimize-
/out:obj/Debug/net461/DapperMySqlCrudExample.exe
/subsystemversion:6.00
/target:exe
/warnaserror-
/utf8output
/deterministic+
/langversion:7.0
